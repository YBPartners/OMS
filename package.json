{
  "name": "yb-oms",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run css:build && vite build",
    "css:build": "npx @tailwindcss/cli -i src/styles/tailwind.css -o public/static/css/tailwind.css --minify",
    "css:watch": "npx @tailwindcss/cli -i src/styles/tailwind.css -o public/static/css/tailwind.css --watch",
    "preview": "wrangler pages dev dist --d1=dahada-production --local --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler pages deploy dist --project-name dahada-oms",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply dahada-production --local",
    "db:seed": "wrangler d1 execute dahada-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console": "wrangler d1 execute dahada-production --local"
  },
  "dependencies": {
    "hono": "^4.12.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
